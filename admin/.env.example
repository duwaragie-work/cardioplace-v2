# Environment Variables for Cardioplace v2 Admin App
# Copy this file to .env.local and fill in your actual values
# Local ports: backend 4000, frontend 3000, admin 3001

# Backend API base URL (NestJS)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Patient app URL — used for cross-links back to the patient-facing app if needed
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
