# Environment Variables for Cardioplace v2 Admin App
# Copy this file to .env.local and fill in your actual values
# Local ports: backend 4000, frontend 3000, admin 3001

# Backend API base URL (NestJS).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Patient app base URL. Used to cross-redirect a logged-in NON-admin user
# (e.g. a PATIENT whose shared API refresh-token cookie rehydrates on the
# admin origin) back to their own dashboard instead of dead-ending on a
# blank /sign-in?reason=forbidden page. Mirror of NEXT_PUBLIC_ADMIN_URL in
# the patient app. Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_PATIENT_URL=http://localhost:3000
