# Environment Variables for Cardioplace v2 Backend
# Copy this file to .env and fill in your actual values
# Local ports: backend 4000, frontend 3000, admin 3001

# ─── Database ──────────────────────────────────────────────────────────────────
# Local dev (Docker or local PostgreSQL):
DATABASE_URL="postgresql://cardioplace:cardioplace@localhost:5432/cardioplace_v2_dev"
# Cloud (e.g. Prisma Postgres / AWS RDS):
# DATABASE_URL="postgres://user:password@host:5432/db?sslmode=require"
# DIRECT_URL is required when using Prisma Accelerate (point at the same DB, bypassing the pooler):
# DIRECT_URL="postgres://user:password@host:5432/db?sslmode=require"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Fresh secrets — do NOT reuse the v1 production values.
# Left BLANK on purpose: the boot guard (src/common/config/secret-guard.ts) refuses
# to start on a placeholder, so shipping "change-me-…" here would just hand every
# new clone a boot failure. Generate a real value per environment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# JWT_ACCESS_SECRET is REQUIRED — the app will not start without it.
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
# JWT_SECRET and JWT_REFRESH_SECRET are not read by any code path today (refresh
# tokens are opaque random bytes, not JWTs). Kept for compatibility; if you set
# them, they must be strong.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ─── MFA (provider/admin TOTP — Manisha 2026-06-12 Access Control §6) ───────────
# Encrypts the TOTP secret at rest (AES-256-GCM). MUST be 64 hex chars (32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this key makes all enrolled secrets undecryptable — every provider
# would have to re-enroll. Treat as a long-lived production secret.
# REQUIRED as of V-06 (2026-07-17) — the app refuses to boot without it.
# Despite the name this is no longer only MFA's key: V-06 encrypts clinical
# free-text (journal notes, medication text, escalation reasons) with it on the
# core write path, so blank no longer means "MFA stays dark", it means every
# check-in carrying a note throws. It must be a REAL key: the boot guard rejects
# all-zero and other low-entropy values the 64-hex format check would accept.
#   Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Treat as a long-lived production secret. Rotating it strands every existing
# ciphertext — there is no key-version field on the envelope yet.
MFA_ENCRYPTION_KEY=
# Issuer label shown in the authenticator app next to the account.
MFA_TOTP_ISSUER=Cardioplace
# Force-enrollment gate. When 'true', provider/admin roles that haven't enrolled
# TOTP are blocked from everything except the enrollment endpoints + logout.
# Deploy with 'false' (dark), then flip to 'true' at cutover once existing test
# users have re-enrolled. Enrolled users are always challenged regardless.
MFA_ENFORCEMENT_ENABLED=false

# ─── Patient biometric (WebAuthn / passkeys — Face ID / fingerprint) ───────────
# Optional, opt-in second factor for PATIENTS only. No enforcement flag — the
# gate fires only when a patient has registered a device from their settings.
# RP ID = the registrable domain, NO scheme / NO port (e.g. 'localhost' in dev,
# 'cardioplaceai.com' in prod). It must match (or be a parent of) the app host.
WEBAUTHN_RP_ID=localhost
# User-visible name shown in the OS biometric prompt.
WEBAUTHN_RP_NAME=Cardioplace
# Full origin(s) the ceremony may run on (the patient app). Comma-separate to
# allow more than one. MUST be https in production (localhost is exempt).
WEBAUTHN_ORIGIN=http://localhost:3000

# ─── Google OAuth (web redirect flow) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v2/auth/google/callback
# Comma-separated list of allowed CORS origins (patient frontend + admin app).
WEB_APP_URL=http://localhost:3000,http://localhost:3001

# Public base URLs — used in escalation email bodies to deep-link recipients.
# Patient recipients get a link into the patient app (/alerts/{alertId});
# provider/admin recipients get a link into the admin app
# (/patients/{userId}?alert={alertId}). Set to the prod domains in prod.
ADMIN_BASE_URL=http://localhost:3001
PATIENT_BASE_URL=http://localhost:3000

# ─── Apple Sign In (mobile + web) ──────────────────────────────────────────────
# Mobile: Bundle ID from your iOS app (for identityToken verification)
APPLE_CLIENT_ID=com.yourcompany.app
# Web: Services ID from Apple Developer Portal (for web redirect flow)
APPLE_SERVICES_ID=com.yourcompany.web
# Required for web flow:
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_CALLBACK_URL=http://localhost:4000/api/v2/auth/apple/callback
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
<your-apple-private-key-here>
-----END PRIVATE KEY-----"

# ─── Email / OTP (SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@yourcompany.com
# Blank = SMTP off (EmailService no-ops / falls back to Resend). If you set it,
# use the app password issued by your mail provider — the boot guard rejects the
# old "your-smtp-app-password" placeholder.
SMTP_PASS=
SMTP_FROM="YourApp <support@yourcompany.com>"

# ─── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Real out-of-app push for PUSH-channel Notifications (service worker + browser
# PushSubscription). Generate a keypair once with: npx web-push generate-vapid-keys
# Leave BLANK to disable push cleanly — WebPushService no-ops (like SMTP unset).
# VAPID_SUBJECT must be a mailto: or https: URL identifying the sender.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@yourcompany.com

# ─── Security paging ───────────────────────────────────────────────────────────
# Where real-time repeated-failed-auth pages are emailed (HIPAA §164.308(a)(6)).
# Leave BLANK to disable the email leg cleanly — the dashboard + push page to
# HEALPLACE_OPS still fire. The email carries the auth identifier + failure
# count only, never patient data.
SECURITY_ALERT_EMAIL=

# ─── Cookies ───────────────────────────────────────────────────────────────────
# 'lax'  → same-domain / subdomain (app.healplace.com + api.healplace.com)
# 'none' → cross-domain, MUST be served over HTTPS
COOKIE_SAME_SITE=lax

# ─── Application ───────────────────────────────────────────────────────────────
PORT=4000

# ─── Feature flags ─────────────────────────────────────────────────────────────
# Caregiver notification dispatch (HF ankle edema + angioedema rules).
# OFF by default. Dispatches the signed-off caregiverMessage to consented,
# active caregivers via their channel (EMAIL via Resend, DASHBOARD for account
# caregivers; SMS captured but not yet deliverable). Flip to true only in
# dev/staging once the capture + consent loop is live; keep OFF in prod until
# the pilot caregiver flow is signed off.
CAREGIVER_DISPATCH_ENABLED=false

# Bug 23 — buffer commits skip the post-commit edit window. When ON, a reading
# the patient explicitly closes ("I'm good" buffer commit / sessionStorage
# auto-commit, with closeSession:true) is finalized immediately: its alert fires
# on create instead of waiting out the 5-min single-reading hold + 2-min
# session-finalize cron (5-10 min latency). The FE "editable for a few more
# minutes" badge is hidden for those entries. Admin, Option D, and chat/voice
# creates are unaffected.
# Default: ON (fast-fire on closeSession commits; Manisha standing approval
# 2026-06-18). Set to 'false' to revert to the legacy single-reading-hold
# behavior (CTO 2026-06-09 policy) — the rollback switch.
BUFFER_SKIPS_DEFER=true

# ─── Gemini (Vertex AI in Google Cloud) ────────────────────────────────────────
# Cardioplace's chat + voice surfaces run exclusively on Vertex AI in GCP.
# Auth is via Application Default Credentials (ADC):
#   • Local dev / CI: point GOOGLE_APPLICATION_CREDENTIALS at the service-
#     account JSON key (the SA needs roles/aiplatform.user on the project).
#   • Cloud Run / GKE / GCE: attach a service account to the runtime — ADC
#     picks it up automatically; leave GOOGLE_APPLICATION_CREDENTIALS unset.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_CHAT_MODEL=gemini-2.5-flash
# Voice runs in-process via @google/genai's Live API on Vertex AI
# (replaces the old Python adk-service on :50051). The default is the GA
# native-audio model — it supports bidirectional audio (bidiGenerateContent)
# and replaces the preview-09-2025 version, which was deprecated and
# removed on 2026-03-19. Override only if Google ships a newer Live-capable
# variant. To list currently-available Live models on your Vertex project:
#   gcloud ai models list --region=us-central1 --project=$GOOGLE_CLOUD_PROJECT
GEMINI_VOICE_MODEL=gemini-live-2.5-flash-native-audio
# Set to 1 to enable verbose per-chunk + per-event voice diagnostics.
# Useful when debugging "listening forever" / no-agent-response stalls.
# Leave unset in production — logs ~3 lines per second under active mic.
# VOICE_DEBUG_AUDIO=1
# Embeddings: all-MiniLM-L6-v2 runs locally via @huggingface/transformers (no API key needed)
# BP photo OCR — per-user daily call limit (NIVA_SILENT_LITERACY_PLAN §3).
OCR_BP_MAX_PER_DAY=20
# Medication-list OCR — per-user daily call limit. Lower than BP because
# med scans are usually one-time (intake / re-edit), not daily.
OCR_MED_MAX_PER_DAY=10

# Drug-name enrichment via RxNorm + DailyMed + OpenFDA. Default 'true' so
# freeform meds get a canonical name + pill image + plain-language description.
# Set 'false' to disable (service returns null and persistence skips the new
# fields). OPENFDA_API_KEY is optional — leaves blank for the free 1000/day
# tier; with a key OpenFDA gives 120/min unlimited daily.
DRUG_ENRICHMENT_ENABLED=true
OPENFDA_API_KEY=

# Phase/27 chatbot v2 system prompt + tool descriptions. Default 'false'
# (v1 prompt) — Manisha clinical sign-off required before flipping. Read
# by both the text chat and the voice agent so flipping it switches both
# in lockstep.
CHAT_V2_PROMPT_ENABLED=false

# #2b (2026-07-18) — clinical-safety guard on chat medication adherence.
# When 'true', a medication marked missed WITHOUT patient-sourced detail
# (submit_checkin: medication_taken=false but no missed_medications; or
# log_medication_adherence status='missed' with no reason) is treated as
# non-alerting instead of firing RULE_MEDICATION_MISSED — so the model cannot
# mint an unearned "missed dose" alert by assuming rather than asking.
# DEFAULT 'false' (today's behavior unchanged). Enabling changes what can fire
# an adherence alert and echoes a previously-removed gate → Manisha sign-off
# required before flipping, same as CHAT_V2_PROMPT_ENABLED.
MED_ADHERENCE_CONFIRM_GUARD_ENABLED=false

# ─── Test-control (qa/ Playwright suite + ops) ───────────────────────────────
# Mounts /test-control/* HTTP endpoints used by the qa/ Playwright suite to
# drive runScan(), backdate timestamps, reset state. The flag is honored only
# when NODE_ENV !== 'production' — defense in depth so a misconfigured prod
# can't expose them. When TEST_CONTROL_SECRET is set, every request must
# include the matching X-Test-Control-Secret header.
ENABLE_TEST_CONTROL=false
TEST_CONTROL_SECRET=

# ─── LangSmith (LLM Monitoring — optional) ────────────────────────────────────
# LANGSMITH_API_KEY=ls_...
# LANGSMITH_PROJECT=healplace-cardio
# LANGSMITH_TRACING_V2=true

# ─── OpenTelemetry / Tracing (optional) ───────────────────────────────────────
# Set to enable OTEL trace export from the NestJS process. No-op when unset.
# Examples:
#   - LangSmith OTLP/HTTP: https://api.smith.langchain.com/otel/v1/traces
#   - Local Jaeger:        http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=cardioplace-backend
# OTEL_SERVICE_VERSION=dev
# When OTEL_EXPORTER_OTLP_ENDPOINT points at LangSmith, LANGSMITH_API_KEY +
# LANGSMITH_PROJECT above are automatically attached as request headers so
# voice spans land in the right project.

# ─── V-17 access-log Pino writer (Ruhaim 2026-07-16 addendum) ────────────────
# Ships DORMANT — the default LOG_SINK=off leaves the current DB-write path in
# access-log.extension.ts untouched. Set LOG_SINK=file locally to exercise the
# rotation + config seam; as of 2026-07-17 the PhiRedactor binding is
# StrictMetadataRedactor (whitelist-projects the known AccessLogData keys), so
# LOG_SINK=file now produces real rows — it was NullRedactor (dropping every
# payload) until V-05 landed. LOG_SINK=s3 is accepted but no S3 transport is
# wired yet (AWS migration pending) — the writer stays dormant on that value.
#
# LOG_SINK = 'off' (default) | 'file' | 's3'
# LOG_SINK=off
#
# When LOG_SINK=file — rotation defaults per addendum's "~100k lines" guidance
# (roughly 50MB at typical JSON line size). Size accepts pino-roll units:
# 'k', 'm', 'g'. Filename convention (pino-roll v4 Extension Last Format):
#   <dir>/access_log.YYYY-MM-DD.N.log
# ACCESS_LOG_FILE_DIR=./logs/access
# ACCESS_LOG_ROTATION_SIZE=50m
#
# Placeholders for the eventual S3 destination — read but NOT wired today.
# The follow-up PR that flips LOG_SINK=s3 to a real S3 transport also needs
# IAM/credentials from the AWS-migration stack.
# ACCESS_LOG_S3_BUCKET=
# ACCESS_LOG_S3_PREFIX=

# ─── V-03 auth rate limiting (Humaira assessment 2026-07-14) ─────────────────
# Number of reverse proxies in front of the app. Express defaults to 0, which
# makes req.ip the SOCKET peer — behind a load balancer that is the LB itself,
# identical for every user, so the auth limiter buckets the whole world together
# and every AccessLog row records the LB's address instead of the actor's.
#
# The value counts hops from the RIGHT of X-Forwarded-For and must match the
# real topology:
#   too LOW  → req.ip is a proxy. Over-throttles + wrong audit IP. Fails CLOSED.
#   too HIGH → req.ip comes from an attacker-supplied XFF segment: they mint a
#              fresh throttle bucket per request and forge the audit IP. Fails
#              OPEN. (This is why `trust proxy: true` is not used — it trusts
#              the leftmost, fully client-controlled, XFF value.)
# 0 / unset = no proxy. Correct for local dev; SET THIS in every deployed env.
# TRUST_PROXY_HOPS=1
#
# Test-only: skip auth rate limiting so suites that deliberately loop auth
# endpoints (backend/test/auth-otp.e2e-spec.ts) don't 429 mid-run.
# DOUBLE-GATED — ignored outright when NODE_ENV=production, so this cannot
# disable the control in prod. Same doctrine as CHAT_VOICE_DEBUG_PHI.
# AUTH_THROTTLE_DISABLED=1

# ─── SMS reminders (Twilio) — L2/L9/L10 ───────────────────────────────────────
# SMS is an ADDITIVE 4th channel on the daily reminder. It is PHI-free and
# directional only: "You have a reminder waiting. Tap here to check in: <link>".
#
# THE KILL-SWITCH. Default OFF — SMS ships dark until healthcare counsel signs
# off on the review packet. Must be the literal string 'true' to send. Turning
# it off cannot affect any other feature: the reminder dispatcher's SMS branch
# is its only consumer, and the branch returns before it even reads the DB.
SMS_REMINDERS_ENABLED=false
#
# Twilio. Both the flag AND all three of these are required before a single
# message goes out (absent credentials → SmsService.isConfigured() is false).
# Use a MESSAGING SERVICE, not a raw from-number: it manages the sender ID and
# honours STOP at the carrier level.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
#
# Sender name shown to patients. Defaults to "Cardioplace" per the team's
# 2026-07-14 decision.
# NOTE: the spec (Part 2C) mandates "Healplace" and explicitly forbids
# "Cardioplace" — naming the cardiac programme on an unencrypted channel
# discloses to anyone who sees the patient's phone that they are in cardiac
# monitoring. This is counsel review question #2; if counsel pushes back, this
# one variable is the whole change.
# The value actually rendered on the handset is whatever the Twilio Messaging
# Service is configured with in the Twilio console — this is our own label.
SMS_SENDER_ID=Cardioplace
#
# Phone numbers are encrypted at rest with the same key as the MFA TOTP secret
# (MFA_ENCRYPTION_KEY above) — set it if you enable SMS.