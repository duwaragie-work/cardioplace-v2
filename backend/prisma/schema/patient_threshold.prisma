model PatientThreshold {
  id              String    @id @default(uuid())
  userId          String    @unique
  sbpUpperTarget  Int?
  sbpLowerTarget  Int?
  dbpUpperTarget  Int?
  dbpLowerTarget  Int?
  hrUpperTarget   Int?
  hrLowerTarget   Int?
  setByProviderId String
  setAt           DateTime  @default(now())
  replacedAt      DateTime?
  notes           String?   @db.Text
  notesEncrypted  String?   @db.Text
  // Inline audit (2026-07-03) — generic edit-actor, auto-stamped from the CLS
  // actor by the access-log extension. setByProviderId stays the clinical
  // "who set this threshold version" (required); createdByActorId/
  // updatedByActorId are the generic any-write actor for the "changed by X"
  // display + any later notes/replacedAt edit. Null for system/pre-policy rows.
  createdByActorId String?
  updatedByActorId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
