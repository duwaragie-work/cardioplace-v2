model User {
  id                      String                   @id @default(ulid())
  // Human-readable public identifier, e.g. "CPPATK8M2R4N7" (canonical) /
  // "CP-PAT-K8M2R4N-7" (display). Set once at account creation, never
  // mutated. Source of truth is the DisplayId ledger; this column is a
  // denormalized fast-path for joins/UI.
  //
  // NOT NULL is enforced by migration
  // 20260624150000_make_user_display_id_required. Every code path that
  // inserts a User row pre-generates the displayId via
  // DisplayIdService.issueForCreate (auth.service.ts) or via the seed
  // helper getOrGenerateDisplayIdForEmail (prisma/seed/display-ids.ts).
  // See docs/UNIQUE_IDENTIFIER_PROPOSAL_2026_06_24.md §11.
  displayId               String                   @unique
  email                   String?                  @unique
  name                    String?
  pwdhash                 String?
  dateOfBirth             DateTime?
  timezone                String?
  communicationPreference CommunicationPreference?
  preferredLanguage       String?                  @default("en")
  isVerified              Boolean                  @default(false)
  roles                   UserRole[]               @default([PATIENT])
  onboardingStatus        OnboardingStatus         @default(NOT_COMPLETED)
  enrollmentStatus        EnrollmentStatus         @default(NOT_ENROLLED)
  // Cluster 8 (Manisha 5/18/26) — stamped when enrollmentStatus first flips
  // to ENROLLED. Drives the CAD-threshold phased ramp (Q2: "newly enrolled"
  // = enrolledAt ≥ rollout start) and the first-month adherence nudge (Q3:
  // within 30 days of enrollment). Migration backfills = createdAt for
  // already-ENROLLED users so existing patients aren't treated as brand new.
  enrolledAt              DateTime?
  accountStatus           AccountStatus            @default(ACTIVE)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  accounts            Account[]
  authLogs            AuthLog[]
  contentSubmitted    Content[]         @relation("ContentSubmittedBy")
  contentRatings      ContentRating[]   @relation("ContentRatings")
  contentReviews      ContentReview[]   @relation("ContentReviewedBy")
  deviationAlerts     DeviationAlert[]
  escalationEvents    EscalationEvent[]
  journalEntries      JournalEntry[]    @relation("PatientJournalEntries")
  journalEntriesAdded JournalEntry[]    @relation("JournalEntryAddedBy")
  notifications       Notification[]
  refreshTokens       RefreshToken[]
  authSessions        AuthSession[]
  scheduledCalls      ScheduledCall[]
  sessions            Session[]
  userDevices         UserDevice[]

  patientProfile                       PatientProfile?
  patientMedications                   PatientMedication[]
  patientThreshold                     PatientThreshold?
  providerAssignmentAsPatient          PatientProviderAssignment?
  providerAssignmentsAsPrimary         PatientProviderAssignment[] @relation("PrimaryProvider")
  providerAssignmentsAsBackup          PatientProviderAssignment[] @relation("BackupProvider")
  providerAssignmentsAsMedicalDirector PatientProviderAssignment[] @relation("MedicalDirector")
  practiceMedicalDirectorMemberships   PracticeMedicalDirector[]   @relation("PracticeMedicalDirectorMemberships")
  practiceProviderMemberships          PracticeProvider[]          @relation("PracticeProviderMemberships")
  practiceCoordinator                  PracticeCoordinator?
  userInvitesSent                      UserInvite[]                @relation("UserInviteInvitedBy")
  userInviteCreated                    UserInvite?                 @relation("UserInviteCreatedUser")
  profileVerificationLogs              ProfileVerificationLog[]
  caregivers                           PatientCaregiver[]          @relation("PatientCaregivers")
  rejectedReadingLogs                  RejectedReadingLog[]

  // MFA — provider/admin TOTP second factor (Manisha 2026-06-12 §6). Both
  // null/empty for patients (their biometric arrives later in its own table).
  totpCredential   TotpCredential?
  mfaRecoveryCodes MfaRecoveryCode[]

  // Patient biometric sign-in (WebAuthn / passkeys). Optional, patient-side;
  // empty for provider/admin accounts. One row per registered device.
  webAuthnCredentials WebAuthnCredential[]

  // Back-relation for the DisplayId ledger row. Always at most one row
  // (DisplayId.userId is @unique). Tombstoned rows (userId = NULL) are
  // not reachable from this side.
  displayIdLedger DisplayId?
}

enum UserRole {
  PATIENT
  PROVIDER
  MEDICAL_DIRECTOR
  COORDINATOR
  HEALPLACE_OPS
  SUPER_ADMIN
}

enum OnboardingStatus {
  NOT_COMPLETED
  COMPLETED
}

enum EnrollmentStatus {
  NOT_ENROLLED
  ENROLLED
}

enum AccountStatus {
  ACTIVE
  BLOCKED
  SUSPENDED
  DEACTIVATED
}
