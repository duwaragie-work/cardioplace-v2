model JournalEntry {
  id                    String      @id @default(uuid())
  userId                String
  measuredAt            DateTime
  // Manisha Backdated Readings sign-off 2026-06-06 — chunk A of backdating
  // implementation. Bucketed window between when the patient says they
  // measured (measuredAt) and when the system received the row (createdAt):
  //
  //   REAL_TIME         (<5 min)        normal current-session entry
  //   NEAR_REAL_TIME    (5 min - <1 h)  acceptable lag (e.g. forgot to log)
  //   DELAYED_ENTRY     (1 h - <24 h)   L2 911 CTA suppressed (provider-only flag)
  //   HISTORICAL_ENTRY  (>=24 h)        L2 not fired (stale data can't confirm
  //                                     active target-organ damage); CMS 99454
  //                                     billing excludes these from 16-day count
  //
  // Default REAL_TIME so existing rows (pre-migration) get a sensible value
  // without backfill. New rows are computed server-side in
  // DailyJournalService.create() from (now - measuredAt).
  delayBand             DelayBand   @default(REAL_TIME)
  systolicBP            Int?
  diastolicBP           Int?
  pulse                 Int?
  weight                Decimal?
  position              Position?
  sessionId             String?
  measurementConditions Json?
  medicationTaken       Boolean?
  // Phase/26 — patient explicitly flagged a medication as "not due yet" on
  // this entry. Lets the gap-alert cron and rule engine distinguish an
  // intentional gap from a missed dose. False default keeps existing rows
  // valid without backfill.
  medicationScheduledLater Boolean  @default(false)
  missedDoses           Int?        @default(0)
  // Per-medication miss detail, snapshot at time of entry so audit trail is
  // stable even if PatientMedication rows are later discontinued or renamed.
  // Shape: Array<{ medicationId, drugName, drugClass, reason, missedDoses }>.
  missedMedications     Json?
  // Per-medication status snapshot for EVERY answered med (taken / missed /
  // scheduledLater), not just the missed ones. Lets the readings edit modal +
  // detail view reconstruct each med's exact answer on reopen — the aggregate
  // medicationTaken + medicationScheduledLater booleans can't disambiguate
  // "med A taken, med B not due yet". Additive + nullable: legacy rows without
  // it fall back to the heuristic rebuild. The rule engine still reads
  // medicationTaken + missedMedications, so this is UI-reconstruction only.
  // Shape: Array<{ medicationId, drugName, drugClass, taken, reason, missedDoses }>.
  medicationStatuses    Json?

  severeHeadache       Boolean @default(false)
  visualChanges        Boolean @default(false)
  alteredMentalStatus  Boolean @default(false)
  chestPainOrDyspnea   Boolean @default(false)
  focalNeuroDeficit    Boolean @default(false)
  severeEpigastricPain Boolean @default(false)

  newOnsetHeadache Boolean @default(false)
  ruqPain          Boolean @default(false)
  edema            Boolean @default(false)

  // Cluster 6 (Manisha 5/10/26) — patient-driven signals for brady-symptomatic
  // (dizziness/syncope), HF decompensation (legSwelling + weightDelta), and
  // palpitations rules. `edema` stays separate — preeclampsia-specific.
  dizziness    Boolean @default(false)
  syncope      Boolean @default(false)
  palpitations Boolean @default(false)
  legSwelling  Boolean @default(false)

  // Cluster 7 (Manisha 5/11/26) — Appendix A side-effect + interaction inputs.
  // fatigue + shortnessOfBreath + dryCough feed β-blocker / ACE / HF rules.
  // nsaidUse captures the per-reading "took NSAID recently" checkbox driving
  // A.3 NSAID + antihypertensive interaction warning.
  fatigue           Boolean @default(false)
  shortnessOfBreath Boolean @default(false)
  dryCough          Boolean @default(false)
  nsaidUse          Boolean @default(false)

  // Cluster 8 (Manisha 5/18/26, P0 pilot blocker) — ACE-angioedema airway
  // emergency. Either symptom fires RULE_ACE_ANGIOEDEMA (ACE/ARB on med list)
  // or RULE_GENERIC_ANGIOEDEMA, Tier 1, for ALL patients regardless of meds.
  faceSwelling    Boolean @default(false)
  throatTightness Boolean @default(false)

  // Cluster 6 Q2 (Manisha 5/9/26) — flag flipped by the 5-min finalize
  // endpoint after the patient's first reading times out without a second
  // reading arriving. Bypasses the non-emergency single-reading gate so the
  // rule engine fires on the lone reading with a "confirm with next session"
  // annotation. Default false; only true on entries that finalized as
  // single-reading sessions.
  singleReadingFinalized Boolean @default(false)

  // Manisha 5/24 Q1 Tier 2 — narrow pulse pressure (SBP−DBP < 15) on this
  // INDIVIDUAL reading at entry. Physician-only artifact flag (no alert tier,
  // no patient message); the reading still enters the session average, where
  // the separate <25 hemodynamic rule may fire. Surfaced on the admin readings
  // tab as a "possible measurement artifact" note.
  narrowPpArtifact Boolean @default(false)

  otherSymptoms String[]

  teachBackAnswer  String?
  teachBackCorrect Boolean?
  notes            String?
  source           EntrySource @default(MANUAL)
  sourceMetadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deviationAlerts DeviationAlert[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, measuredAt])
  @@index([userId, measuredAt(sort: Desc)])
}

enum Position {
  SITTING
  STANDING
  LYING
}

// Manisha Backdated Readings sign-off 2026-06-06 — bucketed lag between when
// the patient says they measured (measuredAt) and when the system received
// the row (createdAt). Drives:
//   • engine: L2 911 CTA suppression on DELAYED_ENTRY (provider-only flag);
//             L2 not fired on HISTORICAL_ENTRY (stale data can't confirm
//             active target-organ damage).
//   • billing: CMS 99454 16-day count excludes HISTORICAL_ENTRY rows.
//   • admin: DELAYED badge + symptom-assessment prompt on physician message.
//   • patient: informational "recorded but won't trigger a real-time alert"
//              note on HISTORICAL_ENTRY (Option B per the policy doc).
enum DelayBand {
  REAL_TIME         // < 5 min — normal current-session entry
  NEAR_REAL_TIME    // 5 min - < 1 h — acceptable lag (forgot to log)
  DELAYED_ENTRY     // 1 h - < 24 h — L2 911 CTA suppressed; provider-only flag
  HISTORICAL_ENTRY  // >= 24 h — L2 not fired; excluded from CMS 99454 count
}

enum DeviationType {
  SYSTOLIC_BP
  DIASTOLIC_BP
  WEIGHT
  MEDICATION_ADHERENCE
}

enum DeviationSeverity {
  LOW
  MEDIUM
  HIGH
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum NotificationChannel {
  PUSH
  EMAIL
  PHONE
  DASHBOARD
}

enum EscalationLevel {
  LEVEL_1
  LEVEL_2
}

enum CommunicationPreference {
  TEXT_FIRST
  AUDIO_FIRST
}

enum EntrySource {
  MANUAL
  HEALTHKIT
}
