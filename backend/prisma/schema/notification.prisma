model Notification {
  id                String              @id @default(uuid())
  userId            String
  alertId           String?
  escalationEventId String?
  // Subject patient for care-team notices that aren't alert-linked (e.g. the
  // IVR-04 enrollment-paused / condition-review notifications). `userId` is the
  // RECIPIENT (provider/MD); this is the patient the notice is ABOUT, so the
  // admin bell/notifications page can deep-link to /patients/{patientUserId}.
  // Alert-linked rows leave this null and derive the patient via `alert.userId`.
  patientUserId     String?
  // Deep-link target for SUPPORT_* notifications so the in-app bell can route
  // into the specific ticket thread (patient → /support my-tickets, ops →
  // admin ticket detail). Plain nullable scalar, mirroring patientUserId — a
  // routing hint, not an enforced FK (no cascade need). Null on all non-support
  // rows. See continue-support-system roadmap Phase 2.5.
  supportTicketId   String?
  channel           NotificationChannel
  title             String
  body              String
  tips              String[]
  sentAt            DateTime            @default(now())
  readAt            DateTime?

  // ── Inline actor attribution (audit, 2026-07-03; HIPAA §164.312(b),
  // Humaira Activity 1). Answers "who caused this notification" from the row
  // itself, without a join to AccessLog. All nullable: pre-fix rows genuinely
  // had no captured actor. Auto-stamped from the CLS actor by the access-log
  // Prisma extension (stampNotificationActor) — call sites don't set these two.
  sentByActorId   String? // User.id (USER) or system-principal id (SYSTEM_ACTOR); null when unknown
  sentByActorType String? // 'USER' | 'SYSTEM_ACTOR' — mirrors AccessLog.actorType
  // Why this notification was sent. Set explicitly by the dispatching service
  // (semantic — can't be inferred from context). This is the SOURCE OF TRUTH
  // for the bell-vs-alerts tab split: the shared BELL_VISIBLE_NOTIFICATION_FILTER
  // hides the ALERT_* triggers (they belong in the Alerts stream) and shows
  // every action/system trigger. Keying off this instead of the nullable
  // `alertId` fixes the leak where an alert row whose journal entry was deleted
  // (DeviationAlert cascade -> Notification.alert onDelete:SetNull nulls alertId)
  // was indistinguishable from a legit null-alertId action row.
  // See project_notification_tab_split_2026_06_04.
  // NOT NULL (enforced by migration): every dispatch path must declare a trigger.
  dispatchTrigger NotificationTrigger
  alert             DeviationAlert?     @relation(fields: [alertId], references: [id], onDelete: SetNull)
  escalationEvent   EscalationEvent?    @relation(fields: [escalationEventId], references: [id], onDelete: SetNull)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Phase/7 — cron retry idempotency. Ensures a given (alert, escalation step,
  // recipient, channel) combo is never double-sent even if the scanner retries.
  @@unique([alertId, escalationEventId, userId, channel])
  @@index([userId, sentAt(sort: Desc)])
  @@index([userId, readAt])
}

// Why a Notification was dispatched. The bell-vs-alerts tab split keys off this
// (not the nullable `alertId`): ALERT_* triggers are hidden from the in-app bell
// because they already render in the Alerts stream; everything else is a
// care-team action or system event and stays visible in the bell.
enum NotificationTrigger {
  // ── Alert-class — HIDDEN from the bell (surfaced via the Alerts stream). ──
  ALERT_CREATED // first ladder dispatch (T+0) for an alert
  ALERT_ESCALATION // subsequent ladder steps (T+4h … T+48h)
  ALERT_RESOLVED // de-escalation / resolution dispatch

  // ── Care-team action-class — VISIBLE in the bell. ──
  EMERGENCY_FLAGGED // chat/voice emergency page to caregivers/providers (no DeviationAlert backing → must stay in the bell)
  CAREGIVER_UPDATE // caregiver-routed alert notice to a consented caregiver inbox
  CARE_TEAM_UPDATE // patient-facing care-team notice (enrollment/condition review)
  THRESHOLD_UPDATED // monitoring targets changed
  MEDICATION_CONTRAINDICATION // intake contraindication flag
  PROFILE_REJECTED // profile correction / rejection
  CALL_SCHEDULED // scheduled-call notice
  SUPPORT_REPLY // support ticket reply (ops → patient)
  SUPPORT_TICKET_CREATED // support ticket created
  SUPPORT_RESOLVE // support ticket resolved
  SUPPORT_USER_REPLIED // patient replied in-thread (→ ops); ball back to ops
  SUPPORT_REOPENED // patient reopened a resolved/closed ticket (→ ops)
  MFA_RESET // MFA reset notice

  // ── System-class — VISIBLE in the bell. ──
  SYSTEM_CRON // cron-emitted notice (gap alert, monthly re-ask, med-hold)
  SYSTEM_ONBOARDING // onboarding system notice
  SYSTEM_SEED // seeded demo notification
  SYSTEM_OTHER // catch-all for un-classified legacy rows (backfill default)

  // ── Security-class — VISIBLE in the bell. ──
  SECURITY_EXCEPTION // real-time audit exception paged to HEALPLACE_OPS (repeated-failed-auth burst, §164.308(a)(6))
}
