model Notification {
  id                String              @id @default(uuid())
  userId            String
  alertId           String?
  escalationEventId String?
  channel           NotificationChannel
  title             String
  body              String
  tips              String[]
  sentAt            DateTime            @default(now())
  readAt            DateTime?
  alert             DeviationAlert?     @relation(fields: [alertId], references: [id], onDelete: SetNull)
  escalationEvent   EscalationEvent?    @relation(fields: [escalationEventId], references: [id], onDelete: SetNull)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt(sort: Desc)])
  @@index([userId, readAt])
  // Phase/7 — cron retry idempotency. Ensures a given (alert, escalation step,
  // recipient, channel) combo is never double-sent even if the scanner retries.
  @@unique([alertId, escalationEventId, userId, channel])
}
