model ScheduledCall {
  id        String          @id @default(uuid())
  userId    String
  alertId   String?
  callDate  String
  callTime  String
  callType  String
  notes     String?
  status    CallStatus      @default(UPCOMING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  alert     DeviationAlert? @relation(fields: [alertId], references: [id])
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([alertId])
  @@index([status, callDate])
}

enum CallStatus {
  UPCOMING
  COMPLETED
  MISSED
  CANCELLED
}
