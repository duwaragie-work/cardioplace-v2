model ProfileVerificationLog {
  id              String                  @id @default(uuid())
  userId          String
  fieldPath       String
  previousValue   Json?
  newValue        Json?
  changedBy       String
  changedByRole   VerifierRole
  changeType      VerificationChangeType
  discrepancyFlag Boolean                 @default(false)
  rationale       String?                 @db.Text
  createdAt       DateTime                @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

enum VerifierRole {
  PATIENT
  ADMIN
  PROVIDER
}

enum VerificationChangeType {
  PATIENT_REPORT
  ADMIN_VERIFY
  ADMIN_CORRECT
  ADMIN_REJECT
  // Phase 2 — Finding 4: clinical-staff actions that previously wrote no
  // audit row. THRESHOLD_UPDATE = MED_DIR/SUPER_ADMIN set/changed a
  // PatientThreshold; ASSIGNMENT_CHANGE = care-team (practice/primary/
  // backup/MD) create or update.
  ADMIN_THRESHOLD_UPDATE
  ADMIN_ASSIGNMENT_CHANGE
  // #85 — one-time historical data cleanup (brand/generic dedup merge). Kept
  // distinct from ADMIN_CORRECT so auditors can tell migration-merged rows
  // apart from human provider corrections.
  SYSTEM_MIGRATION
}
