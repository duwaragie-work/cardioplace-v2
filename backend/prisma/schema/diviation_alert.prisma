model DeviationAlert {
  id             String @id @default(uuid())
  userId         String
  journalEntryId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  type      DeviationType?
  severity  DeviationSeverity?
  magnitude Decimal?           @db.Decimal(6, 2)

  baselineValue Decimal? @db.Decimal(6, 2)
  actualValue   Decimal? @db.Decimal(6, 2)

  tier                  AlertTier?
  ruleId                String?
  mode                  AlertMode?
  pulsePressure         Int?
  suboptimalMeasurement Boolean    @default(false)

  patientMessage    String? @db.Text
  caregiverMessage  String? @db.Text
  physicianMessage  String? @db.Text

  dismissible         Boolean @default(true)
  resolutionAction    String?
  resolutionRationale String? @db.Text
  resolvedBy          String?

  escalated Boolean     @default(false)
  status    AlertStatus @default(OPEN)

  createdAt            DateTime  @default(now())
  acknowledgedAt       DateTime?
  // JCAHO 15-field audit-trail columns (bug #2 + #8). All nullable so the
  // additive migration doesn't disturb existing rows; backfill migration
  // populates resolvedAt + acknowledgedByUserId from EscalationEvent where
  // possible. updatedAt has @updatedAt so subsequent writes track changes;
  // existing rows pick up CURRENT_TIMESTAMP at migration time.
  acknowledgedByUserId String?
  resolvedAt           DateTime?
  updatedAt            DateTime  @updatedAt @default(now())

  escalationEvents EscalationEvent[]
  notifications    Notification[]
  scheduledCalls   ScheduledCall[]

  // Phase/7 — dropped @@unique([journalEntryId, type]). v2 allows multiple
  // alerts per entry (e.g. Tier 3 pulse-pressure annotation alongside a Tier 1
  // contraindication). Engine enforces app-level dedup by (journalEntryId, ruleId)
  // in the upsert logic.
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([journalEntryId, ruleId])
}

enum AlertTier {
  TIER_1_CONTRAINDICATION
  TIER_2_DISCREPANCY
  TIER_3_INFO
  BP_LEVEL_1_HIGH
  BP_LEVEL_1_LOW
  BP_LEVEL_2
  BP_LEVEL_2_SYMPTOM_OVERRIDE
  // Cluster 8 (Manisha 5/18/26) — ACE-angioedema. Tier-1 class
  // (non-dismissable) but routed to its own compressed escalation ladder
  // (T+0 → T+15m → T+1h → T+4h) instead of the standard Tier 1 ladder.
  TIER_1_ANGIOEDEMA
}

enum AlertMode {
  STANDARD
  PERSONALIZED
}
