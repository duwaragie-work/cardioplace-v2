model DeviationAlert {
  id             String @id @default(uuid())
  userId         String
  journalEntryId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  type      DeviationType?
  severity  DeviationSeverity?
  magnitude Decimal?           @db.Decimal(6, 2)

  baselineValue Decimal? @db.Decimal(6, 2)
  actualValue   Decimal? @db.Decimal(6, 2)

  tier                  AlertTier?
  ruleId                String?
  mode                  AlertMode?
  pulsePressure         Int?
  suboptimalMeasurement Boolean    @default(false)

  patientMessage    String? @db.Text
  caregiverMessage  String? @db.Text
  physicianMessage  String? @db.Text

  dismissible         Boolean @default(true)
  resolutionAction    String?
  resolutionRationale String? @db.Text
  resolvedBy          String?

  escalated Boolean     @default(false)
  status    AlertStatus @default(OPEN)

  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?

  escalationEvents EscalationEvent[]
  notifications    Notification[]
  scheduledCalls   ScheduledCall[]

  @@unique([journalEntryId, type])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
}

enum AlertTier {
  TIER_1_CONTRAINDICATION
  TIER_2_DISCREPANCY
  TIER_3_INFO
  BP_LEVEL_1_HIGH
  BP_LEVEL_1_LOW
  BP_LEVEL_2
  BP_LEVEL_2_SYMPTOM_OVERRIDE
}

enum AlertMode {
  STANDARD
  PERSONALIZED
}
