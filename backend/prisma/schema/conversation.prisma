model Conversation {
  id          String                      @id @default(uuid())
  sessionId   String
  userMessage          String
  userMessageEncrypted String?
  aiSummary            String
  aiSummaryEncrypted   String?
  source      String                      @default("text")
  embedding   Unsupported("vector(384)")?
  timestamp   DateTime                    @default(now())

  @@index([sessionId])
}
