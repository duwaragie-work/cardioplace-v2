model EscalationEvent {
  id                 String          @id @default(uuid())
  alertId            String
  userId             String
  escalationLevel    EscalationLevel
  reason             String?
  triggeredAt        DateTime        @default(now())
  notificationSentAt DateTime?

  ladderStep          LadderStep?
  recipientIds        String[]
  recipientRoles      String[]
  acknowledgedAt      DateTime?
  acknowledgedBy      String?
  resolvedAt          DateTime?
  resolvedBy          String?
  notificationChannel NotificationChannel?
  afterHours          Boolean              @default(false)

  // Phase/7 — BP L2 resolution action #6 (Unable to reach patient — will retry)
  // writes a new EscalationEvent with scheduledFor=now+4h + triggeredByResolution=true.
  // The cron scanner dispatches at scheduledFor instead of computing from ladder offset.
  scheduledFor          DateTime?
  triggeredByResolution Boolean   @default(false)

  // Phase 2 — Finding 5: explicit system-vs-human dispatch attribution
  // (JCAHO). true = auto-dispatched by the escalation scheduler (cron) with
  // no human actor; false = scheduled by an admin action (BP_L2 retry).
  // Replaces the prior admin-UI heuristic with a persisted, queryable fact.
  dispatchedBySystem Boolean @default(false)

  // June 2026 — practice-context attribution (Manisha 2026-06-12 Access
  // Control §1, HIPAA 45 CFR §164.312(a)(2)(i)). The activePracticeId on
  // the actor's AuthSession at the time of acknowledge/resolve. NULL for
  // cron-dispatched ladders (dispatchedBySystem=true) and pre-policy
  // events. Indexed for "audit by practice" queries.
  actorPracticeContext String?

  alert         DeviationAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([alertId, triggeredAt(sort: Desc)])
  @@index([userId, triggeredAt(sort: Desc)])
  @@index([scheduledFor])
  @@index([actorPracticeContext, triggeredAt(sort: Desc)])
}

enum LadderStep {
  T0
  // Cluster 8 (Manisha 5/18/26) — angioedema compressed ladder. Airway
  // emergency escalates far faster than the standard Tier 1 ladder:
  // T+15m backup, T+1h medical director + ops.
  T15M
  T1H
  T2H
  T4H
  T8H
  T24H
  T48H
  // Phase/23 — BP Level 1 ladder. Same wall-clock offsets reused across both
  // BP_LEVEL_1_HIGH and BP_LEVEL_1_LOW (router picks via alert.tier). T72H is
  // the medical-director step, T7D is the Healplace-ops compliance flag.
  T72H
  T7D
  TIER2_48H
  TIER2_7D
  TIER2_14D
}
