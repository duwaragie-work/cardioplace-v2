// Patient biometric sign-in (WebAuthn / passkeys — Face ID / fingerprint).
// OPTIONAL convenience layer on top of OTP: a patient who opts in registers a
// platform authenticator on a supported device, then can sign in with a touch.
// OTP always remains the fallback (devices without biometrics, or a new
// device). Providers/admins use TOTP instead — this table is patient-side.
//
// One row per registered authenticator (a patient may enable it on more than
// one device), so this is 1:many with User. The WebAuthn challenge is NOT
// stored here — it rides in a short-lived signed JWT during the register /
// authenticate ceremony (same stateless pattern as TOTP enrollment), so no
// challenge table is needed.
model WebAuthnCredential {
  id           String    @id @default(ulid())
  userId       String
  // Authenticator-assigned credential id (base64url). Unique across all users
  // — the login ceremony looks the credential up by this value.
  credentialId String    @unique
  // COSE public key for signature verification (base64url-encoded bytes).
  publicKey    String
  // Signature counter — increments per use; a non-increasing value signals a
  // possible cloned authenticator (verification rejects it).
  counter      Int       @default(0)
  // Transport hints from registration (e.g. ["internal"], ["hybrid"]) — used
  // to improve the browser prompt UX on subsequent logins.
  transports   String[]
  // From registration: "singleDevice" | "multiDevice", plus whether the
  // credential is backed up (synced passkey). Informational for the UI.
  deviceType   String?
  backedUp     Boolean   @default(false)
  // Optional user-facing label (e.g. "iPhone 15", "Pixel") for the
  // "your devices" management list.
  deviceName   String?

  // PER-DEVICE BINDING (2026-07-14). The `x-device-id` of the browser/device
  // this passkey was created on. Biometric is a second factor ONLY on the
  // device that registered it: at sign-in we challenge only when the incoming
  // deviceId has a credential for this user. Signing in from ANY other device
  // falls back to OTP / magic-link and never prompts for biometric — the
  // patient can opt in for that device separately from Settings.
  //
  // NULL means "not bound to a device" — legacy rows registered before this
  // change, and any row created without an x-device-id header. Those are never
  // challenged (fail-open, consistent with the opt-in posture) and the patient
  // simply re-enables biometric on the device they want it on.
  deviceId     String?

  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // The sign-in hot path: "does THIS device hold a passkey for this user?"
  @@index([userId, deviceId])
}
