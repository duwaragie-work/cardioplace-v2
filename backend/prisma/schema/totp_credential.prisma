// Provider/admin TOTP second factor (Manisha 2026-06-12 Access Control §6,
// HIPAA 45 CFR §164.312(d)). One authenticator secret per user — hence the
// one-to-one (userId @unique). The secret is AES-256-GCM encrypted at rest
// (never stored plaintext); the encryption key lives in MFA_ENCRYPTION_KEY.
// enrolledAt == null (or no row) means "not yet enrolled". mfaResetByAdminAt
// is stamped when a SUPER_ADMIN / HEALPLACE_OPS forces re-enrollment.
model TotpCredential {
  id                String    @id @default(ulid())
  userId            String    @unique
  secretEncrypted   String
  enrolledAt        DateTime?
  mfaResetByAdminAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
