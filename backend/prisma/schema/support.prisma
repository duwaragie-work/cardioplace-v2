// Support System Phase 1 (HIPAA sprint — Nivakaran). Administrative support
// channel, separate from the clinical AI chat. Handles the signed-in contact
// form AND the locked-out (unauthenticated) flow, ops triage + reply, and the
// privileged reset actions gated behind manual identity verification.
//
// Enums are native (codebase convention) even though the sprint appendix wrote
// them as String — same fixed value sets, with DB-level type safety.

model SupportTicket {
  id     String @id @default(ulid())
  // Human-readable public handle, e.g. "CP-SUP-K8M2R4N-7" (canonical stored,
  // hyphenated). Quoted on support calls; generated by TicketNumberService.
  ticketNumber String @unique

  // NULL when raised from the locked-out flow (no authenticated user). SetNull
  // so a tombstoned account doesn't cascade-delete the audit trail.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Always captured — the reply-to address (equals the user's email for
  // signed-in tickets; free-typed for locked-out).
  email             String
  category          SupportCategory
  subject           String
  body              String              @db.Text
  status            SupportStatus       @default(OPEN)
  priority          SupportPriority     @default(NORMAL)
  contactPreference SupportContactPref?

  // FALSE until ops verifies identity (phone callback + security questions).
  // Signed-in tickets land TRUE (already authenticated); locked-out land FALSE.
  // The three privileged reset actions are blocked until this is TRUE.
  identityVerified Boolean @default(false)

  assignedToOpsId String?
  ipAddress       String?
  userAgent       String?

  createdAt  DateTime  @default(now())
  // @updatedAt bumps on every ticket write (status flip, reply-driven
  // transition, assignment). @default(now()) gives existing rows + the DB
  // column a value so the hand-authored migration's DEFAULT matches the schema
  // (no future drift). Used by the ops queue for "recently active".
  updatedAt  DateTime  @default(now()) @updatedAt
  resolvedAt DateTime?
  // Set when the auto-close cron (or a future manual close) moves a RESOLVED
  // ticket to CLOSED. The cron anchors on resolvedAt; closedAt records the event.
  closedAt   DateTime?
  // Set when a patient reopens a RESOLVED/CLOSED ticket within the reopen
  // window. A reopened ticket is excluded from the auto-close sweep.
  reopenedAt DateTime?

  replies SupportTicketReply[]
  actions SupportTicketAction[]

  @@index([status, createdAt])
  @@index([userId])
  // Auto-close sweep scans RESOLVED tickets by resolvedAt.
  @@index([status, resolvedAt])
}

model SupportTicketReply {
  id       String        @id @default(ulid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorType   SupportAuthorType // USER | OPS
  authorUserId String? // the ops agent, or the original ticket user
  body         String            @db.Text
  sentAt       DateTime          @default(now())

  @@index([ticketId, sentAt])
}

// Every privileged action ops takes on a ticket — the ticket-local audit trail.
// (Duwaragie's request-scoped AccessLog also captures the actor via CLS; this
// row is the ticket-facing timeline the ops UI renders.)
model SupportTicketAction {
  id       String        @id @default(ulid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  opsUserId   String // the support agent who performed it
  actionType  SupportActionType
  metadata    Json? // e.g. { method: "phone callback", reason, verifiedFields }
  performedAt DateTime @default(now())

  @@index([ticketId, performedAt])
}

enum SupportCategory {
  ACCOUNT
  MFA
  CLINICAL
  BUG
  OTHER
}

// Four-state lifecycle (Duwaragie, 2026-07-21). Deliberately does NOT store an
// "awaiting reply" state: whose turn it is is DERIVED from the last reply's
// authorType (see deriveAwaitingParty in support.service.ts) — a stored copy was
// functionally identical and could drift from the thread it describes. A reopen
// likewise returns the ticket to IN_PROGRESS rather than adding a state; the
// `reopenedAt` timestamp is what records that it happened.
enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  // Terminal. Set by the auto-close cron N days after RESOLVED with no activity.
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
}

enum SupportContactPref {
  EMAIL
  PHONE
}

enum SupportAuthorType {
  USER
  OPS
}

enum SupportActionType {
  MFA_RESET
  RECOVERY_CODES_REGEN
  WEBAUTHN_RESET
  ACCOUNT_UNLOCKED
  IDENTITY_VERIFIED
  RESOLVED
  // S4/S5 (ops queue) — both carry an opsUserId, so they fit the ops-only
  // SupportTicketAction. Patient reopen + cron auto-close are NOT actions
  // (no ops actor); they are tracked via status + reopenedAt/closedAt.
  ASSIGNED
  PRIORITY_CHANGED
}
