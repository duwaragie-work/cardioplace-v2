model PatientMedication {
  id                       String                       @id @default(uuid())
  userId                   String
  drugName                 String
  drugClass                DrugClass
  isCombination            Boolean                      @default(false)
  combinationComponents    String[]
  frequency                MedicationFrequency
  source                   MedicationSource
  verificationStatus       MedicationVerificationStatus @default(UNVERIFIED)
  verifiedByAdminId        String?
  verifiedAt               DateTime?
  reportedAt               DateTime                     @default(now())
  discontinuedAt           DateTime?
  // Manisha 5/24 Med §3 — structured HOLD reason (drives the two-path patient
  // message: PROVIDER_DIRECTED_HOLD = "pause it" clinical instruction; the
  // administrative reasons = "keep taking it" informational). holdSetAt anchors
  // the 7/14/30/45-day reconciliation escalation ladder.
  holdReason               MedicationHoldReason?
  holdSetAt                DateTime?
  // Manisha 5/24 Med §4 — reconciliation escalation ladder progress (0 = none,
  // 1 = day-7, 2 = day-14, 3 = day-30, 4 = day-45). Bumped by the hold-
  // escalation cron so a given rung never double-fires; reset to 0 when the
  // medication leaves HOLD.
  holdEscalationLevel      Int                          @default(0)
  rawInputText                      String?
  rawInputTextEncrypted             String?
  notes                             String?                      @db.Text
  notesEncrypted                    String?                      @db.Text
  pillImageUrl                      String?
  plainLanguageDescription          String?                      @db.Text
  plainLanguageDescriptionEncrypted String?                      @db.Text
  // #85 — canonical drug identity (shared catalog `id`, e.g. "losartan" for
  // BOTH Cozaar and Losartan), resolved via matchToCatalog(drugName). Enables
  // brand/generic dedup. Null for off-catalog / free-text meds — dedup skipped.
  canonicalDrugId          String?
  // #92 — admin-add provenance. source distinguishes patient self-report from
  // an admin-entered med; the added*/lastEdited* fields record who/when.
  addedByUserId            String?
  addedByRole              VerifierRole?
  addedAt                  DateTime?
  lastEditedByUserId       String?
  lastEditedByRole         VerifierRole?
  lastEditedAt             DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, discontinuedAt])
  @@index([userId, verificationStatus])
  @@index([userId, canonicalDrugId])
}

enum DrugClass {
  ACE_INHIBITOR
  ARB
  BETA_BLOCKER
  DHP_CCB
  NDHP_CCB
  LOOP_DIURETIC
  THIAZIDE
  MRA
  SGLT2
  ANTICOAGULANT
  STATIN
  ANTIARRHYTHMIC
  VASODILATOR_NITRATE
  ARNI
  // Cluster 7 — NSAIDs (ibuprofen, naproxen, celecoxib) blunt antihypertensive
  // efficacy + raise BP. A.3 rule warns the patient when they report NSAID use
  // while on any antihypertensive.
  NSAID
  OTHER_UNVERIFIED
}

enum MedicationFrequency {
  ONCE_DAILY
  TWICE_DAILY
  THREE_TIMES_DAILY
  AS_NEEDED
  UNSURE
}

enum MedicationSource {
  PATIENT_SELF_REPORT
  PROVIDER_ENTERED
  PATIENT_VOICE
  PATIENT_PHOTO
}

enum MedicationVerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
  AWAITING_PROVIDER
  // Cluster 7 A.7 — provider has placed the medication on hold pending review.
  // Triggers SYSTEM_MSG_MEDICATION_HOLD to the patient's inbox + suppresses
  // adherence rule fires for this med until status returns to VERIFIED.
  HOLD
}

// Manisha 5/24 Med §3 — structured HOLD reason codes. Only PROVIDER_DIRECTED_HOLD
// is a clinical "stop taking it" instruction; the rest are administrative
// ("keep taking it, we're reviewing the paperwork"). OTHER requires free text.
enum MedicationHoldReason {
  AWAITING_RECORDS
  UNCLEAR_NAME
  UNCLEAR_DOSE
  PROVIDER_DIRECTED_HOLD
  OTHER
}
