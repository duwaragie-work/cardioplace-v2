# Workspaces (npm workspaces hoists to root node_modules)
node_modules/
**/node_modules/

# Backend
backend/dist/
backend/.env
backend/.env.production
backend/.env.local
backend/.env.shared-backup
*.shared-backup
backend/src/generated/
# transformers.js embedding-model cache (~86MB all-MiniLM-L6-v2). Lives outside
# node_modules so it survives `npm ci`, which would otherwise force a fresh
# download every reinstall — and an interrupted download leaves a truncated
# model.onnx that fails with "Protobuf parsing failed" (2026-07-22).
backend/.model-cache/

# Frontend
frontend/.next/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.production

# Admin
admin/.next/
admin/dist/
admin/.env
admin/.env.local
admin/.env.production

# QA (Playwright suite reads its own env for the test stack)
qa/.env
qa/.env.local
qa/.env.production

# Shared
shared/dist/
shared/*.tsbuildinfo

# Python
__pycache__/
*.pyc

# OS
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-error.log*

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

# Tests
coverage/
.nyc_output/
# Playwright artifacts
qa/test-results/
qa/playwright-report/
qa/reports/

# Temp
.temp
.tmp

.claude

cardioplace-vertex-sa.json