# Workspaces (npm workspaces hoists to root node_modules)
node_modules/
**/node_modules/

# Backend
backend/dist/
backend/.env
backend/.env.production
backend/.env.local
backend/src/generated/

# Frontend
frontend/.next/
frontend/dist/
frontend/.env.local
frontend/.env.production

# Admin
admin/.next/
admin/dist/
admin/.env.local
admin/.env.production

# Shared
shared/dist/
shared/*.tsbuildinfo

# Python
__pycache__/
*.pyc

# OS
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-error.log*

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

# Tests
coverage/
.nyc_output/

# Temp
.temp
.tmp

.claude