# Environment Variables for Cardioplace v2 Patient Frontend
# Copy this file to .env.local and fill in your actual values
# Local ports: backend 4000, frontend 3000, admin 3001

# Backend API base URL (NestJS)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Admin app URL — used by proxy.ts to redirect SUPER_ADMIN users off the patient app
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# ─── OCR feature flags (NIVA_SILENT_LITERACY_PLAN §3) ─────────────────────────
# Each flag gates a 44×44 camera button + its confirm modal in the intake
# wizard. Both render to null when the flag is anything other than 'true', so
# you can disable per-feature without redeploying.
#
# BP photo OCR — adds a camera button on the daily check-in BP step.
NEXT_PUBLIC_BP_OCR_ENABLED=true
# Medication-list OCR — adds a "Scan prescription" button on /clinical-intake
# A5 (medications) and on the Profile → Edit Medications deep-link.
NEXT_PUBLIC_MED_OCR_ENABLED=true
