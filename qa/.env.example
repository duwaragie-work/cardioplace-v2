# Cardioplace v2 QA — copy to .env.local (gitignored). Suite defaults to local.
# Three services must be running before `npm run test`:
#   backend  :4000  (cd backend && npm run start:dev)
#   frontend :3000  (cd frontend && npm run dev)
#   admin    :3001  (cd admin && npm run dev)
# DB must be seeded: cd backend && npx prisma db seed

# ─── Targets ─────────────────────────────────────────────────────────────────
PATIENT_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:4000

# ─── Seed accounts (perma-OTP via backend/prisma/seed.ts) ────────────────────
DEMO_OTP=666666
PATIENT_PRIYA_EMAIL=priya.menon@cardioplace.test
PATIENT_JAMES_EMAIL=james.okafor@cardioplace.test
PATIENT_RITA_EMAIL=rita.washington@cardioplace.test
PATIENT_CHARLES_EMAIL=charles.brown@cardioplace.test
PATIENT_AISHA_EMAIL=aisha.johnson@cardioplace.test

ADMIN_MANISHA_EMAIL=manisha.patel@cardioplace.test
ADMIN_SUPPORT_EMAIL=support@healplace.com
ADMIN_PRIMARY_PROVIDER_EMAIL=primary-provider@cardioplace.test
ADMIN_BACKUP_PROVIDER_EMAIL=backup-provider@cardioplace.test
ADMIN_MD_EMAIL=medical-director@cardioplace.test
ADMIN_OPS_EMAIL=ops@healplace.com

# ─── Test-control feature flags ──────────────────────────────────────────────
# Backend must be started with ENABLE_TEST_CONTROL=true for cron + escalation
# specs to drive runScan() deterministically. Defaults off in prod.
ENABLE_TEST_CONTROL=true

# Optional shared secret for /test-control endpoints. If set, the suite passes
# X-Test-Control-Secret header. Backend rejects mismatched/missing.
TEST_CONTROL_SECRET=change-me-locally

# ─── Optional flags ──────────────────────────────────────────────────────────
# Skip write-tests (check-in submissions, alert resolution, ladder advance).
# RUN_WRITE_TESTS=1

# Run LLM safety eval against /chat (paid via Gemini).
# RUN_LLM_TESTS=1

# Run mobile + multi-engine matrix instead of chromium-desktop only.
# RUN_FULL_MATRIX=1
